# Motif gateway — copy to server/.env and fill in values.
# Never commit server/.env.

# --- Auth (required in production) ---
# Google OAuth client ID (Chrome extension type)
GOOGLE_OAUTH_CLIENT_ID=

# Comma-separated Google user IDs (sub). Email is display-only.
MOTIF_ALLOWED_SUBS=

# Optional readable allowlist (gitignored). Env subs are merged with this file.
# MOTIF_ALLOWED_USERS_FILE=allowed_users.json

# Random secret for Motif session JWTs (32+ bytes)
MOTIF_JWT_SECRET=

# Session lifetime in seconds (default 24h)
MOTIF_JWT_TTL_SECONDS=86400

# Local dev only — bypass auth (never set in production)
# MOTIF_AUTH_DISABLED=1

# --- Gateway ---
# MOTIF_GATEWAY_HOST=127.0.0.1
# MOTIF_GATEWAY_PORT=8787
# MOTIF_SUPERTONIC_URL=http://127.0.0.1:7788
